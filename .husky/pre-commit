if command -v fnm >/dev/null 2>&1; then
  eval "$(fnm env --shell bash 2>/dev/null)" 2>/dev/null || true
elif [ -s "$HOME/.nvm/nvm.sh" ]; then
  . "$HOME/.nvm/nvm.sh" 2>/dev/null || true
fi

if [ -f "node_modules/.bin/lint-staged" ]; then
  node_modules/.bin/lint-staged
fi

CHANGED=$(git diff --cached --name-only)
ROOT_DIR=$(pwd)
TSC="$ROOT_DIR/node_modules/.bin/tsc"

if [ ! -f "$TSC" ]; then
  exit 0
fi

for app in carrier-admin cliente platform-admin; do
  if echo "$CHANGED" | grep -q "^apps/$app/"; then
    printf "→ tsc check: apps/%s\n" "$app"
    find "apps/$app" -name "*.tsbuildinfo" -delete 2>/dev/null || true
    (cd "apps/$app" && "$TSC" -b --noEmit) || exit 1
  fi
done

if echo "$CHANGED" | grep -q "^backend/"; then
  printf "→ tsc check: backend\n"
  (cd backend && "$TSC" --noEmit) || exit 1
fi
